{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/config-schema.jsonc",
  "name": "skyfi-mcp",
  "main": "src/worker.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],

  // Secrets (set via `wrangler secret put`):
  //   SKYFI_API_KEY    — SkyFi Platform API key
  //   SKYFI_BASE_URL   — (optional) override the SkyFi API base URL
  //   LANGCHAIN_API_KEY — (optional) LangSmith tracing key

  // Observability: enable Worker-level logging
  "observability": {
    "enabled": true
  }
}
