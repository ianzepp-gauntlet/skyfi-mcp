{
  "name": "skyfi-mcp-server",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "check": "bun x tsc --noEmit",
    "evals": "bun run scripts/run-evals.ts",
    "evals:planner-smoke": "bun run scripts/run-evals.ts --suite planner-smoke",
    "evals:live-smoke": "bun run scripts/run-evals.ts --suite live-smoke",
    "docs:sync-examples": "node scripts/verify-doc-examples.mjs --write",
    "docs:verify": "node scripts/verify-doc-examples.mjs --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:cf": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@eslint/js": "^10.0.1",
    "@stoplight/prism-cli": "^5.14.2",
    "@types/bun": "latest",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0",
    "wrangler": "^4",
    "yaml": "^2.8.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents": "^0.7.6",
    "hono": "^4.12.5",
    "zod": "^4.3.6"
  }
}
